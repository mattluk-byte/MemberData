<Window x:Class="ClubApp.Views.MemberEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Member Edit" Height="400" Width="300">
    <Grid>
        <TextBox Name="NameTextBox" PlaceholderText="Name"/>
        <TextBox Name="EmailTextBox" PlaceholderText="Email"/>
        <Button Content="Save" Command="{Binding SaveCommand}"/>
    </Grid>
</Window>