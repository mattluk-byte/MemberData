<Window x:Class="ClubApp.Views.FeeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="編輯會費項目" Height="230" Width="400" WindowStartupLocation="CenterOwner">
  <StackPanel Margin="12">
    <TextBlock Text="代碼" />
    <TextBox Text="{Binding Fee.Code}" />
    <TextBlock Text="名稱" Margin="0,6,0,0"/>
    <TextBox Text="{Binding Fee.Name}" />
    <TextBlock Text="金額" Margin="0,6,0,0"/>
    <TextBox Text="{Binding Fee.Amount}" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="儲存" Command="{Binding SaveCommand}" Width="90" Margin="6"/>
      <Button Content="取消" Command="{Binding CancelCommand}" Width="90" Margin="6"/>
    </StackPanel>
  </StackPanel>
</Window>